# service settings
SVC_MODE=sim
SVC_MIN_DWELL_SECONDS=20
SVC_DATA_DIR=data
SENSORS_CONFIG_FILE=svc/data/sensors_config.json
SVC_ENABLE_T10A_IN_SIM=false
SVC_ENABLE_JETI_SERIAL_IN_SIM=false
SVC_ENABLE_EKO_IN_SIM=false

# real vendor adapter placeholders  only used when SVC_MODE=real
HALIO_API_URL=https://api.halio.com
HALIO_SITE_ID=
HALIO_API_KEY=
