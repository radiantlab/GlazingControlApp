{
    "name": "glazing-web",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "typecheck:watch": "tsc --noEmit --watch --preserveWatchOutput",
        "watch": "node ../scripts/watch.mjs",
        "watch:backend": "node ../scripts/watch.mjs backend",
        "watch:frontend": "node ../scripts/watch.mjs frontend",
        "watch:both": "node ../scripts/watch.mjs both",
        "build": "vite build",
        "preview": "vite preview"
    },
    "dependencies": {
        "react": "18.2.0",
        "react-dom": "18.2.0",
        "react-router-dom": "^7.13.0",
        "recharts": "^3.7.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@types/react": "18.2.28",
        "@types/react-dom": "18.2.8",
        "jsdom": "25.0.1",
        "typescript": "5.3.3",
        "vite": "5.4.10",
        "vitest": "2.1.8"
    }
}
